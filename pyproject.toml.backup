[project]
name = "cirrhosis-prediction"
version = "0.1.0"
description = "Cirrhosis Patient Survival Prediction & MLOps"
authors = [
    {name = "Neruff",email = "roman.r1ff@mail.ru"}
]
license = {text = "MIT"}
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
    "pandas (>=3.0.1,<4.0.0)",
    "numpy (>=2.4.3,<3.0.0)",
    "scikit-learn (>=1.8.0,<2.0.0)",
    "matplotlib (>=3.10.8,<4.0.0)",
    "seaborn (>=0.13.2,<0.14.0)",
    "jupyter (>=1.1.1,<2.0.0)",
    "catboost (>=1.2.10,<2.0.0)",
    "optuna (>=4.7.0,<5.0.0)",
    "loguru (>=0.7.3,<0.8.0)",
    "typer (>=0.24.1,<0.25.0)",
    "python-dateutil (>=2.9.0.post0,<3.0.0)"
]


[build-system]
requires = ["poetry-core>=2.0.0,<3.0.0"]
build-backend = "poetry.core.masonry.api"
